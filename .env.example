# Dify API
DIFY_API_BASE=https://dify.web.moontontech.net/v1
DIFY_PLANNER_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx
DIFY_ANALYST_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx
# 题型识别专用 Chat 应用（System Prompt 见 docs/column_detect_prompt.md）
DIFY_COLUMN_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx
# 数据标注模块
DIFY_AI_DETECT_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx   # AI 作答识别（新建 Dify 应用）
DIFY_QUALITY_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx     # 回答质量打标（已有 Dify 应用）

# 主观题大样本聚类 / 跑数表模式（Workflow 应用，倍市得 V2 时期已建）
DIFY_THEME_EXTRACT_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx   # 大样本-主题提取（Workflow）
DIFY_THEME_MERGE_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx     # 大样本-主题合并（Workflow）
DIFY_CLASSIFY_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx        # 大样本-回复分类（Workflow）
DIFY_LARGE_ANALYST_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx   # 报告撰写助手（大样本/跑数表版）
DIFY_CROSSTAB_PLANNER_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx # 跑数表模式-章节大纲策划（chat 应用）

# 飞书导出（OAuth 网页登录）。配置步骤见 docs/feishu_oauth.md
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE=https://open.feishu.cn/open-apis
FEISHU_REDIRECT_URI=https://<部署域名>/api/feishu/callback
# 留空使用飞书开放平台里为应用开通的默认权限。
# 不要只填 drive:file:upload；导出 docx 还需要“查看、创建云文档导入任务”等权限。
FEISHU_SCOPE=

# 飞书整站登录（邮箱白名单）
FEISHU_LOGIN_REQUIRED=true
FEISHU_ALLOWED_EMAILS=user1@example.com,user2@example.com
FEISHU_SESSION_DAYS=7
