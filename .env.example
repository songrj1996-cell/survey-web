# 题型识别专用 Chat 应用（System Prompt 见 docs/column_detect_prompt.md）
DIFY_COLUMN_KEY=app-xxxxxxxxxxxxxxxxxxxxxxx

# 飞书导出（OAuth 网页登录）。配置步骤见 docs/feishu_oauth.md
